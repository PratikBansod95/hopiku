{
  "name": "hopiku",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:playable": "npm run compress:assets && npm run build && node scripts/package-playable.mjs",
    "generate:sfx": "node scripts/generate-sfx.mjs",
    "strip:ui": "python scripts/strip-ui-alpha.py",
    "generate:skins": "python scripts/generate-panda-skins.py",
    "import:skins": "python scripts/import-skin-assets.py",
    "compress:assets": "python scripts/compress-assets.py",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.3",
    "vitest": "^3.0.5"
  }
}
